{
  "manifest_version": 3,
  "name": "Web Safe",
  "version": "0.2.0",
  "description": "Оценивает риск сайта по URL, базам угроз, DNS/RDAP и признакам страницы.",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Web Safe",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "scripts": [
      "src/background.js"
    ],
    "service_worker": "src/background.js",
    "preferred_environment": [
      "document",
      "service_worker"
    ],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "web-safe@local.dev",
      "data_collection_permissions": {
        "required": [
          "websiteActivity"
        ]
      }
    }
  }
}
